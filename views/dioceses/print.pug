extends ../layouts/print

block content
  .print-page
    .print-header
      .print-logo
        i.fas.fa-cross
      .print-title
        h1 Diocese Priest Management System
        h2 Official Dioceses Registry
      .print-date
        p Date Printed: #{new Date().toLocaleDateString('en-GB', {day:'2-digit', month:'long', year:'numeric'})}

    .print-divider

    .print-summary-row
      .print-summary-item
        span.summary-label Total Dioceses
        span.summary-value= dioceses.length
      .print-summary-item
        span.summary-label Active
        span.summary-value= dioceses.filter(d => d.isActive).length
      .print-summary-item
        span.summary-label Inactive
        span.summary-value= dioceses.filter(d => !d.isActive).length
      .print-summary-item
        span.summary-label Total Priests Assigned
        span.summary-value= dioceses.reduce((acc, d) => acc + (d.priests ? d.priests.length : 0), 0)

    .print-divider

    table.print-table.print-table-full
      thead
        tr
          th.col-num #
          th Diocese Name
          th Description
          th Priests
          th Status
      tbody
        each diocese, i in dioceses
          tr(class=!diocese.isActive ? 'row-inactive' : '')
            td.col-num= i + 1
            td
              strong= diocese.name
            td.desc-col= diocese.description || '—'
            td.center= diocese.priests ? diocese.priests.length : 0
            td.center
              span(class=`print-badge ${diocese.isActive ? 'print-badge-active' : 'print-badge-inactive'}`)
                = diocese.isActive ? 'Active' : 'Inactive'

    .print-divider

    //- Priest breakdown per diocese
    h3.section-heading Priests by Diocese
    each diocese in dioceses
      if diocese.priests && diocese.priests.length > 0
        .diocese-breakdown
          .breakdown-header
            strong= diocese.name
            span.priest-count= diocese.priests.length + ' priest(s)'
          table.print-table.breakdown-table
            thead
              tr
                th #
                th Priest Name
                th Place of Work
                th Status
            tbody
              each priest, j in diocese.priests
                tr
                  td= j + 1
                  td= priest.fullName
                  td= priest.placeOfWork || '—'
                  td= priest.priestStatus ? priest.priestStatus.replace('_', ' ') : '—'

    .print-footer
      .print-signature
        .sig-line
          p ____________________________
          p Authorized Signature
        .sig-line
          p ____________________________
          p Date
        .sig-line
          p ____________________________
          p Official Stamp
      p.print-footer-note This is an official document generated by the Diocese Priest Management System.
