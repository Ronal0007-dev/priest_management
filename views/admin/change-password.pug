extends ../layouts/main

block content
  .form-page
    .page-header
      h2
        i.fas.fa-key
        |  Change Password
      a(href="/admin/dashboard" class="btn btn-secondary")
        i.fas.fa-arrow-left
        |  Back

    .account-grid
      .form-card
        h3.step-title
          span.step-badge
            i.fas.fa-lock
          |  Update Your Password

        .info-note
          i.fas.fa-info-circle
          span Password must be at least 6 characters long.

        form(action="/admin/change-password" method="POST" id="changePassForm")
          .form-group
            label Current Password *
            .input-icon-wrap
              i.fas.fa-lock.input-icon
              input#currentPassword(
                type="password"
                name="currentPassword"
                placeholder="Enter your current password"
                required
                autocomplete="current-password"
              )
              button.toggle-pw-btn(type="button" onclick="togglePw('currentPassword','icon0')" tabindex="-1")
                i.fas.fa-eye#icon0

          .form-group
            label New Password *
            .input-icon-wrap
              i.fas.fa-key.input-icon
              input#newPassword(
                type="password"
                name="newPassword"
                placeholder="Enter new password (min. 6 characters)"
                required
                autocomplete="new-password"
                oninput="checkStrength(this.value)"
              )
              button.toggle-pw-btn(type="button" onclick="togglePw('newPassword','icon1')" tabindex="-1")
                i.fas.fa-eye#icon1

          .strength-bar-wrap#strengthWrap(style="display:none")
            .strength-bar
              .strength-fill#strengthFill
            span.strength-label#strengthLabel

          .form-group
            label Confirm New Password *
            .input-icon-wrap
              i.fas.fa-check-circle.input-icon
              input#confirmPassword(
                type="password"
                name="confirmPassword"
                placeholder="Re-enter new password"
                required
                autocomplete="new-password"
                oninput="checkMatch()"
              )
              button.toggle-pw-btn(type="button" onclick="togglePw('confirmPassword','icon2')" tabindex="-1")
                i.fas.fa-eye#icon2

          #matchMsg.match-msg(style="display:none")

          .form-actions
            button(type="submit" class="btn btn-primary" id="submitBtn")
              i.fas.fa-save
              |  Change Password

      .security-tip-card
        .tip-header
          i.fas.fa-shield-alt
          h3 Password Tips
        ul.tip-list
          li
            i.fas.fa-check
            span Use at least 8 characters
          li
            i.fas.fa-check
            span Mix uppercase and lowercase letters
          li
            i.fas.fa-check
            span Include numbers and symbols
          li
            i.fas.fa-check
            span Avoid using your name or username
          li
            i.fas.fa-check
            span Don't reuse old passwords
        .tip-divider
        .tip-footer
          i.fas.fa-info-circle
          p
            | Forgotten your password?&nbsp;
            a(href="/forgot-password") Use the reset flow
            |  on the login page.

  script.
    function togglePw(inputId, iconId) {
      const inp = document.getElementById(inputId);
      const ico = document.getElementById(iconId);
      if (inp.type === 'password') {
        inp.type = 'text';
        ico.classList.replace('fa-eye', 'fa-eye-slash');
      } else {
        inp.type = 'password';
        ico.classList.replace('fa-eye-slash', 'fa-eye');
      }
    }

    function checkStrength(val) {
      const wrap = document.getElementById('strengthWrap');
      const fill = document.getElementById('strengthFill');
      const label = document.getElementById('strengthLabel');
      wrap.style.display = val.length ? '' : 'none';
      if (!val.length) return;

      let score = 0;
      if (val.length >= 6) score++;
      if (val.length >= 10) score++;
      if (/[A-Z]/.test(val)) score++;
      if (/[0-9]/.test(val)) score++;
      if (/[^A-Za-z0-9]/.test(val)) score++;

      const levels = [
        { pct: '20%', color: '#dc3545', text: 'Very Weak' },
        { pct: '40%', color: '#f59e0b', text: 'Weak' },
        { pct: '60%', color: '#eab308', text: 'Fair' },
        { pct: '80%', color: '#22c55e', text: 'Strong' },
        { pct: '100%', color: '#15803d', text: 'Very Strong' }
      ];
      const lvl = levels[Math.min(score - 1, 4)] || levels[0];
      fill.style.width = lvl.pct;
      fill.style.background = lvl.color;
      label.textContent = lvl.text;
      label.style.color = lvl.color;
    }

    function checkMatch() {
      const np = document.getElementById('newPassword').value;
      const cp = document.getElementById('confirmPassword').value;
      const msg = document.getElementById('matchMsg');
      if (!cp) { msg.style.display = 'none'; return; }
      msg.style.display = '';
      if (np === cp) {
        msg.textContent = '✓ Passwords match';
        msg.className = 'match-msg match-ok';
      } else {
        msg.textContent = '✗ Passwords do not match';
        msg.className = 'match-msg match-error';
      }
    }
