extends ../layouts/auth

block content
  .login-page
    .login-brand
      .brand-icon
        i.fas.fa-shield-alt
      h1.brand-title Password Recovery
      p.brand-subtitle Diocese Priest Management System

    .login-card
      .forgot-steps
        .forgot-step.done
          .fstep-circle
            i.fas.fa-check
          span Find Account
        .fstep-line.done
        .forgot-step.active
          .fstep-circle 2
          span Verify
        .fstep-line
        .forgot-step
          .fstep-circle 3
          span New Password

      h2.login-heading Verify Your Identity
      p.login-subtext
        | Account: &nbsp;
        strong= username

      if flash && flash.error && flash.error.length
        .alert.alert-error
          i.fas.fa-exclamation-circle
          span= flash.error[0]

      .question-box
        i.fas.fa-question-circle
        p= question

      form(action="/forgot-password/verify" method="POST")
        .form-group
          label
            i.fas.fa-comment-dots
            |  Your Answer
          input(
            type="text"
            name="answer"
            placeholder="Type your security answer"
            required
            autofocus
            autocomplete="off"
          )
        .case-note
          i.fas.fa-info-circle
          span Answers are not case-sensitive

        button.btn-login(type="submit")
          i.fas.fa-arrow-right
          |  Verify Answer

      .back-link
        a(href="/forgot-password")
          i.fas.fa-arrow-left
          |  Back

    .login-footer
      p &copy; #{new Date().getFullYear()} Diocese Priest Management System
