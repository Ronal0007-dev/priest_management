extends ../layouts/print

block content
  .print-page
    .print-header
      .print-logo
        i.fas.fa-cross
      .print-title
        h1 Diocese Priest Management System
        h2 Official Priest Record
      .print-date
        p Date Printed: #{new Date().toLocaleDateString('en-GB', {day:'2-digit', month:'long', year:'numeric'})}

    .print-profile
      .print-photo-section
        if priest.photo
          img.print-photo(src=`/uploads/${priest.photo}` alt=priest.fullName)
        else
          .print-photo.print-photo-placeholder
            i.fas.fa-user-tie
      .print-name-section
        h2= priest.fullName
        p.print-status Status: #{priest.priestStatus.replace('_', ' ').toUpperCase()}
        if priest.diocese
          p.print-diocese Diocese: #{priest.diocese.name}
        if priest.placeOfWork
          p Place of Work: #{priest.placeOfWork}

    .print-divider

    .print-sections
      .print-section
        h3
          span.section-num 1
          |  Personal Information
        table.print-table
          tr
            th Full Name
            td= priest.fullName
          tr
            th Date of Birth
            td= priest.dateOfBirth ? new Date(priest.dateOfBirth).toLocaleDateString('en-GB', {day:'2-digit', month:'long', year:'numeric'}) : '—'
          tr
            th Place of Birth
            td= `${priest.placeOfBirthCity || '—'}, ${priest.placeOfBirthCountry || '—'}`
          tr
            th Marital Status
            td= priest.maritalStatus ? priest.maritalStatus.charAt(0).toUpperCase() + priest.maritalStatus.slice(1) : '—'

      .print-section
        h3
          span.section-num 2
          |  Baptism Information
        table.print-table
          tr
            th Date of Baptism
            td= priest.dateOfBaptism ? new Date(priest.dateOfBaptism).toLocaleDateString('en-GB', {day:'2-digit', month:'long', year:'numeric'}) : '—'
          tr
            th Place of Baptism
            td= priest.placeOfBaptism || '—'
          tr
            th Baptized By
            td= priest.baptizedBy || '—'

      .print-section
        h3
          span.section-num 3
          |  Confirmation Information
        table.print-table
          tr
            th Date of Confirmation
            td= priest.dateOfConfirmation ? new Date(priest.dateOfConfirmation).toLocaleDateString('en-GB', {day:'2-digit', month:'long', year:'numeric'}) : '—'
          tr
            th Place of Confirmation
            td= priest.placeOfConfirmation || '—'
          tr
            th Bishop Who Confirmed
            td= priest.confirmationBishop || '—'

      .print-section
        h3
          span.section-num 4
          |  Education Information
        table.print-table
          tr
            th Primary School
            td= priest.primarySchool || '—'
          tr
            th Secondary School
            td= priest.secondarySchool || '—'
          tr
            th College
            td
              = priest.college || '—'
              if priest.college && priest.collegeSpecialization
                em  (#{priest.collegeSpecialization})
          tr
            th University
            td
              = priest.university || '—'
              if priest.university && priest.universitySpecialization
                em  (#{priest.universitySpecialization})

      .print-section
        h3
          span.section-num 5
          |  Theology & Ministry
        table.print-table
          tr
            th Theology Level
            td= priest.theologyLevel || '—'
          tr
            th Theology Institution
            td= priest.theologyInstitution || '—'
          tr
            th Ordination Date
            td= priest.ordinationDate ? new Date(priest.ordinationDate).toLocaleDateString('en-GB', {day:'2-digit', month:'long', year:'numeric'}) : '—'
          tr
            th Diocese
            td= priest.diocese ? priest.diocese.name : '—'
          tr
            th Place of Work
            td= priest.placeOfWork || '—'
          tr
            th Date Assigned
            td= priest.dateAssigned ? new Date(priest.dateAssigned).toLocaleDateString('en-GB', {day:'2-digit', month:'long', year:'numeric'}) : '—'
          tr
            th Status
            td= priest.priestStatus ? priest.priestStatus.replace('_', ' ').toUpperCase() : '—'

    .print-footer
      .print-signature
        .sig-line
          p ____________________________
          p Authorized Signature
        .sig-line
          p ____________________________
          p Date
        .sig-line
          p ____________________________
          p Official Stamp
      p.print-footer-note This is an official document generated by the Diocese Priest Management System.
